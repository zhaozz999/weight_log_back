<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AppUserMapper">

    <resultMap id="AppUserResult" type="com.ruoyi.system.domain.AppUser">
        <id property="userId" column="user_id" />
        <result property="openId" column="open_id" />
        <result property="nickName" column="nick_name" />
        <result property="avatarUrl" column="avatar_url" />
        <result property="gender" column="gender" />
        <result property="status" column="status" />
        <result property="lastLoginTime" column="last_login_time" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAppUserColumns">
        select user_id, open_id, nick_name, avatar_url, gender, status, last_login_time, create_time, update_time, remark
        from app_user
    </sql>

    <select id="selectByUserId" parameterType="Long" resultMap="AppUserResult">
        <include refid="selectAppUserColumns" />
        where user_id = #{userId}
    </select>

    <select id="selectUserList" resultMap="AppUserResult">
        <include refid="selectAppUserColumns" />
        <where>
            <if test="nickName != null and nickName != ''">
                and nick_name like concat('%', #{nickName}, '%')
            </if>
        </where>
        order by user_id desc
    </select>

    <select id="selectByOpenId" parameterType="String" resultMap="AppUserResult">
        <include refid="selectAppUserColumns" />
        where open_id = #{openId}
    </select>

    <insert id="insertAppUser" parameterType="com.ruoyi.system.domain.AppUser" useGeneratedKeys="true" keyProperty="userId">
        insert into app_user (
            open_id,
            nick_name,
            avatar_url,
            gender,
            status,
            last_login_time,
            create_time,
            update_time,
            remark
        ) values (
            #{openId},
            #{nickName},
            #{avatarUrl},
            #{gender},
            #{status},
            #{lastLoginTime},
            #{createTime},
            #{updateTime},
            #{remark}
        )
    </insert>

    <update id="updateAppUser" parameterType="com.ruoyi.system.domain.AppUser">
        update app_user
        <set>
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="avatarUrl != null">avatar_url = #{avatarUrl},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="status != null">status = #{status},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where user_id = #{userId}
    </update>

    <delete id="deleteByUserId" parameterType="Long">
        delete from app_user where user_id = #{userId}
    </delete>
</mapper>
